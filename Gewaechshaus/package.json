{
  "name": "gewachshaus-raspi",
  "version": "3.0.0",
  "description": "Gewächshaus Steuerungssystem - Raspberry Pi optimiert (keine npm-Abhängigkeiten)",
  "main": "server-simple.js",
  "scripts": {
    "start": "node server-simple.js",
    "start:old": "node server.js",
    "dev": "node --watch server-simple.js",
    "start:daemon": "bash ./start.sh daemon",
    "start:status": "bash ./start.sh status",
    "start:stop": "bash ./start.sh stop",
    "start:restart": "bash ./start.sh restart",
    "start:logs": "bash ./start.sh logs"
  },
  "dependencies": {
    "nodemailer": "^6.9.9"
  },
  "keywords": [
    "greenhouse",
    "raspberry-pi",
    "iot",
    "fertilizer"
  ],
  "author": "Lernfeld 7 Projektteam",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  }
}
